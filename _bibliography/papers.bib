@article{sanchez2026opensocint,
  bibtex_show = {true},
  title       = {OpenSocInt: A Multi-modal Training Environment for Human-Aware Social Navigation},
  author      = {Sanchez, Victor and Reinke, Chris and Mohamed, Ahamed and Alameda-Pineda, Xavier},
  journal     = {arXiv preprint arXiv:2601.01939},
  abstract    = {In this paper, we introduce OpenSocInt, an open-source software package providing a simulator
                for multi-modal social interactions and a modular architecture to train social agents. We described the
                software package and showcased its interest via an experimental protocol based on the task of social
                navigation. Our framework allows for exploring the use of different perceptual features, their encoding
                and fusion, as well as the use of different agents. The software is already publicly available under GPL
                at https://gitlab.inria.fr/robotlearn/OpenSocInt/},
  url         = {https://arxiv.org/pdf/2601.01939},
